VITE_UNICLOUD_BASE_URL=https://your-env-id.example.com

# Optional: use these when each cloud function has an independent URL.
# VITE_ADMIN_SYS_URL=https://your-env-id.example.com/cicada-admin-sys
# VITE_ADMIN_KB_URL=https://your-env-id.example.com/cicada-admin-kb
# VITE_ADMIN_ORDER_URL=https://your-env-id.example.com/cicada-admin-order
# VITE_CLIENT_PUBLIC_URL=https://your-env-id.example.com/cicada-client-public

# Local mock backend for offline development:
# 1. Copy this file to .env.local.
# 2. Uncomment the lines below.
# 3. Run `npm run mock` and `npm run dev`.
# VITE_UNICLOUD_BASE_URL=http://localhost:8787
# VITE_ADMIN_SYS_URL=http://localhost:8787/cicada-admin-sys
# VITE_ADMIN_KB_URL=http://localhost:8787/cicada-admin-kb
# VITE_ADMIN_ORDER_URL=http://localhost:8787/cicada-admin-order
